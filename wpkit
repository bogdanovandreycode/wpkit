#!/usr/bin/env php
<?php

use Symfony\Component\Console\Application;
use Wpkit\Command\AiCheckCommand;
use Wpkit\Command\AiDiffCommand;
use Wpkit\Command\AiFindCommand;
use Wpkit\Command\AiIndexBuildCommand;
use Wpkit\Command\AiIndexRemoveCommand;
use Wpkit\Command\AiIndexShowCommand;
use Wpkit\Command\AiIndexUpdateCommand;
use Wpkit\Command\AiReadCommand;
use Wpkit\Command\AiStatusCommand;
use Wpkit\Command\AiWriteCommand;
use Wpkit\Command\LanguageAddCommand;
use Wpkit\Command\LanguageRemoveCommand;
use Wpkit\Command\LintCheckCommand;
use Wpkit\Command\LocaleAddCommand;
use Wpkit\Command\LocaleRemoveCommand;
use Wpkit\Command\LocaleShowCommand;
use Wpkit\Command\LocaleUpdateCommand;
use Wpkit\Command\NamespaceUpdateCommand;
use Wpkit\Command\PluginCreateCommand;
use Wpkit\Command\PluginCreateFromFileCommand;
use Wpkit\Command\PluginInitConfigCommand;
use Wpkit\Command\ProjectBuildCommand;
use Wpkit\Command\RouteCreateCommand;
use Wpkit\Command\ScaffoldMakeCommand;
use Wpkit\Controller\ScaffoldCatalog;

$autoloadFiles = [
    __DIR__ . '/vendor/autoload.php',
    __DIR__ . '/../../autoload.php',
];

$autoloadFound = false;

foreach ($autoloadFiles as $autoloadFile) {

    if (file_exists($autoloadFile)) {
        require_once $autoloadFile;
        $autoloadFound = true;

        break;
    }
}

if (!$autoloadFound) {
    fwrite(STDERR, "Composer autoload.php not found. Checked:\n");

    foreach ($autoloadFiles as $autoloadFile) {
        fwrite(STDERR, " - {$autoloadFile}\n");
    }

    exit(1);
}

$application = new Application();

$application->add(new AiCheckCommand());
$application->add(new AiDiffCommand());
$application->add(new AiFindCommand());
$application->add(new AiIndexBuildCommand());
$application->add(new AiIndexRemoveCommand());
$application->add(new AiIndexShowCommand());
$application->add(new AiIndexUpdateCommand());
$application->add(new AiReadCommand());
$application->add(new AiStatusCommand());
$application->add(new AiWriteCommand());
$application->add(new LanguageAddCommand());
$application->add(new LanguageRemoveCommand());
$application->add(new LocaleAddCommand());
$application->add(new LocaleRemoveCommand());
$application->add(new LocaleShowCommand());
$application->add(new LocaleUpdateCommand());
$application->add(new PluginCreateCommand());
$application->add(new NamespaceUpdateCommand());
$application->add(new RouteCreateCommand());
$application->add(new PluginCreateFromFileCommand());
$application->add(new PluginInitConfigCommand());
$application->add(new LintCheckCommand());
$application->add(new ProjectBuildCommand());

foreach (ScaffoldCatalog::makeDefinitions() as $definition) {
    $application->add(new ScaffoldMakeCommand($definition));
}

$application->run();
